    float ACES2_SampleReach(float h)
    {
        float hh = h - floor(h / 360.0) * 360.0;
        int i0 = (int)floor(hh);
        int i1 = (i0 + 1) % 360;
        float t = hh - floor(hh);
        return lerp(ACES2_reachM[i0], ACES2_reachM[i1], t);
    }

    // Returns (cuspJ, cuspM, gammaTopInv) interpolated for hue h.
    float3 ACES2_SampleCusp(float h)
    {
        float hh = h - floor(h / 360.0) * 360.0;
        int i0 = (int)floor(hh);
        int i1 = (i0 + 1) % 360;
        float t = hh - floor(hh);
        float cj = lerp(ACES2_cuspJ[i0], ACES2_cuspJ[i1], t);
        float cm = lerp(ACES2_cuspM[i0], ACES2_cuspM[i1], t);
        float gt = lerp(ACES2_gammaTopInv[i0], ACES2_gammaTopInv[i1], t);
        return float3(cj, cm, gt);
    }
};
